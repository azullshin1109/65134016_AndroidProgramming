<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center|top"
    tools:context=".MainActivity">

    <Button
        android:id="@+id/nutso1"
        android:text="NÚT BẤM SỐ 1"
        android:textSize="25dp"
        android:textColor="@color/black"
        android:background="#ADCEED"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        />

    <Button
        android:id="@+id/nutso2"
        android:text="NÚT BẤM SỐ 2"
        android:textSize="30dp"
        android:textColor="@color/black"
        android:background="#2673B9"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        />

    <Button
        android:id="@+id/nutso3"
        android:text="NÚT BẤM SỐ 3"
        android:textSize="35dp"
        android:textColor="@color/black"
        android:background="#1B3C7F"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        />

</LinearLayout>